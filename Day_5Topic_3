Target architecture
force-app/main/default/
├── triggers/
│   ├── AccountTrigger.trigger          2 lines
│   ├── OpportunityTrigger.trigger      2 lines
│   └── CaseTrigger.trigger             2 lines
└── classes/
    ├── TriggerHandler.cls              base — dispatch + bypass
    ├── RecursionGuard.cls              Set<Id> per logical operation
    ├── AccountTriggerHandler.cls       context routing only
    ├── AccountService.cls              logic, plain collections
    ├── OpportunityTriggerHandler.cls
    ├── OpportunityService.cls
    ├── CaseTriggerHandler.cls
    ├── CaseService.cls
    └── TriggerBulkTest.cls

The rule that drives every file: handlers know about Trigger; services don't. A service method takes List<Account> and Map<Id, Account> and has no idea whether it was called from a trigger, a Queueable, or a test.

Foundation
public virtual class TriggerHandler {

    private static Set<String> bypassed = new Set<String>();

    public static void bypass(String name)      { bypassed.add(name); }
    public static void clearAllBypasses()       { bypassed.clear(); }
    public static Boolean isBypassed(String n)  { return bypassed.contains(n); }

    @TestVisible private Boolean isExecuting;
    @TestVisible private TriggerOperation context;

    public TriggerHandler() {
        this.isExecuting = Trigger.isExecuting;
        this.context     = Trigger.operationType;
    }

    public void run() {
        if (!isExecuting) {
            throw new TriggerHandlerException('run() called outside trigger context');
        }
        if (isBypassed(String.valueOf(this).substringBefore(':'))) return;

        switch on this.context {
            when BEFORE_INSERT  { beforeInsert();  }
            when BEFORE_UPDATE  { beforeUpdate();  }
            when BEFORE_DELETE  { beforeDelete();  }
            when AFTER_INSERT   { afterInsert();   }
            when AFTER_UPDATE   { afterUpdate();   }
            when AFTER_DELETE   { afterDelete();   }
            when AFTER_UNDELETE { afterUndelete(); }
        }
    }

    protected virtual void beforeInsert()  {}
    protected virtual void beforeUpdate()  {}
    protected virtual void beforeDelete()  {}
    protected virtual void afterInsert()   {}
    protected virtual void afterUpdate()   {}
    protected virtual void afterDelete()   {}
    protected virtual void afterUndelete() {}

    public class TriggerHandlerException extends Exception {}
}

public class RecursionGuard {

    private static Map<String, Set<Id>> processed = new Map<String, Set<Id>>();

    public static Set<Id> claim(String key, Set<Id> candidates) {
        if (!processed.containsKey(key)) processed.put(key, new Set<Id>());
        Set<Id> seen  = processed.get(key);
        Set<Id> fresh = new Set<Id>(candidates);
        fresh.removeAll(seen);
        seen.addAll(fresh);
        return fresh;
    }

    @TestVisible static void reset() { processed.clear(); }
}

