Refactor 2 — Opportunity, the bulkified showcase

This is the one that has to survive 200 records. It does two things at once — insert child Tasks and roll a sum up to the parent Account — which is where non-bulkified code usually dies.

apex
trigger OpportunityTrigger on Opportunity (
    before insert, before update, before delete,
    after insert, after update, after delete, after undelete
) {
    new OpportunityTriggerHandler().run();
}

public with sharing class OpportunityTriggerHandler extends TriggerHandler {

    private List<Opportunity>    newList = (List<Opportunity>) Trigger.new;
    private List<Opportunity>    oldList = (List<Opportunity>) Trigger.old;
    private Map<Id, Opportunity> oldMap  = (Map<Id, Opportunity>) Trigger.oldMap;

    protected override void afterInsert() {
        OpportunityService.createKickoffTasks(newList);
        OpportunityService.rollupToAccounts(accountIds(newList, null));
    }

    protected override void afterUpdate() {
        OpportunityService.createKickoffTasks(changedToKickoffStage());
        OpportunityService.rollupToAccounts(accountIds(newList, oldList));
    }

    protected override void afterDelete() {
        OpportunityService.rollupToAccounts(accountIds(null, oldList));
    }

    protected override void afterUndelete() {
        OpportunityService.rollupToAccounts(accountIds(newList, null));
    }

    /** Union of parent Ids across both versions — catches reparenting. */
    private Set<Id> accountIds(List<Opportunity> a, List<Opportunity> b) {
        Set<Id> ids = new Set<Id>();
        if (a != null) for (Opportunity o : a) if (o.AccountId != null) ids.add(o.AccountId);
        if (b != null) for (Opportunity o : b) if (o.AccountId != null) ids.add(o.AccountId);
        return ids;
    }

    private List<Opportunity> changedToKickoffStage() {
        List<Opportunity> result = new List<Opportunity>();
        for (Opportunity o : newList) {
            if (o.StageName != oldMap.get(o.Id).StageName) result.add(o);
        }
        return result;
    }
}

accountIds taking both lists is the detail people skip: if an Opportunity moves from Account A to Account B, both parents need recalculating. Only collecting from Trigger.new leaves A permanently wrong.

public with sharing class OpportunityService {

    private static final Set<String> KICKOFF_STAGES =
        new Set<String>{ 'Prospecting', 'Qualification' };

    @TestVisible static Integer lastQueryCount;   // instrumentation for bulk tests
    @TestVisible static Integer lastDmlCount;

    // ------------------------------------------------------------------
    public static void createKickoffTasks(List<Opportunity> opps) {

        if (opps == null || opps.isEmpty()) return;

        List<Task> toInsert = new List<Task>();

        for (Opportunity o : opps) {                       // no SOQL, no DML in here
            if (!KICKOFF_STAGES.contains(o.StageName)) continue;
            toInsert.add(new Task(
                WhatId       = o.Id,
                OwnerId      = o.OwnerId,
                Subject      = 'Kickoff call: ' + o.Name,
                ActivityDate = Date.today().addDays(3),
                Priority     = 'High',
                Status       = 'Not Started'
            ));
        }

        if (toInsert.isEmpty()) return;

        for (Database.SaveResult sr : Database.insert(toInsert, false)) {
            if (!sr.isSuccess()) {
                System.debug(LoggingLevel.ERROR, 'Task failed: ' + sr.getErrors()[0].getMessage());
            }
        }
    }

    // ------------------------------------------------------------------
    public static void rollupToAccounts(Set<Id> accountIds) {

        if (accountIds == null || accountIds.isEmpty()) return;

        Set<Id> toProcess = RecursionGuard.claim('OpportunityService.rollup', accountIds);
        if (toProcess.isEmpty()) return;

        Integer q0 = Limits.getQueries();
        Integer d0 = Limits.getDmlStatements();

        // ---- ONE aggregate query for every parent ----
        Map<Id, Decimal> wonTotals = new Map<Id, Decimal>();
        Map<Id, Integer> openCount = new Map<Id, Integer>();

        for (AggregateResult ar : [
            SELECT AccountId aid, StageName stage, SUM(Amount) amt, COUNT(Id) cnt
            FROM Opportunity
            WHERE AccountId IN :toProcess
            GROUP BY AccountId, StageName
        ]) {
            Id aid      = (Id) ar.get('aid');
            String st   = (String) ar.get('stage');
            Decimal amt = (Decimal) ar.get('amt');
            Integer cnt = (Integer) ar.get('cnt');

            if (st == 'Closed Won') {
                wonTotals.put(aid, (wonTotals.containsKey(aid) ? wonTotals.get(aid) : 0) + amt);
            } else if (st != 'Closed Lost') {
                openCount.put(aid, (openCount.containsKey(aid) ? openCount.get(aid) : 0) + cnt);
            }
        }

        // ---- ONE query for the parents ----
        List<Account> toUpdate = new List<Account>();

        for (Account a : [
            SELECT Id, Won_Revenue__c, Open_Opp_Count__c
            FROM Account WHERE Id IN :toProcess
        ]) {
            Decimal won  = wonTotals.containsKey(a.Id) ? wonTotals.get(a.Id) : 0;
            Integer open = openCount.containsKey(a.Id) ? openCount.get(a.Id) : 0;

            // ---- only DML records that actually changed ----
            if (a.Won_Revenue__c != won || a.Open_Opp_Count__c != open) {
                a.Won_Revenue__c    = won;
                a.Open_Opp_Count__c = open;
                toUpdate.add(a);
            }
        }

        if (!toUpdate.isEmpty()) update toUpdate;

        lastQueryCount = Limits.getQueries() - q0;
        lastDmlCount   = Limits.getDmlStatements() - d0;
    }
}

Cost profile: 2 SOQL + at most 2 DML, whether the trigger got 1 record or 200. The GROUP BY AccountId, StageName collapses what would otherwise be a per-account query into one. The change-comparison before adding to toUpdate is doing double duty — it saves DML rows and it's the reason the Account trigger doesn't get re-entered pointlessly.

Refactor 3 — Case validation
apex
trigger CaseTrigger on Case (
    before insert, before update, before delete,
    after insert, after update, after delete, after undelete
) {
    new CaseTriggerHandler().run();
}
apex
public with sharing class CaseTriggerHandler extends TriggerHandler {
    protected override void beforeUpdate() {
        CaseService.validateClosure(
            (List<Case>) Trigger.new,
            (Map<Id, Case>) Trigger.oldMap
        );
    }
}

public with sharing class CaseService {

    public static void validateClosure(List<Case> cases, Map<Id, Case> oldMap) {

        // PHASE 1 — collect only records transitioning into Closed
        Set<Id> closing = new Set<Id>();
        for (Case c : cases) {
            if (c.Status == 'Closed' && oldMap.get(c.Id).Status != 'Closed') {
                closing.add(c.Id);
            }
        }
        if (closing.isEmpty()) return;              // exits before spending any SOQL

        // PHASE 2 — one aggregate query
        Map<Id, Integer> openTasks = new Map<Id, Integer>();
        for (AggregateResult ar : [
            SELECT WhatId wid, COUNT(Id) cnt
            FROM Task
            WHERE WhatId IN :closing AND IsClosed = false
            GROUP BY WhatId
        ]) {
            openTasks.put((Id) ar.get('wid'), (Integer) ar.get('cnt'));
        }

        // PHASE 3 — apply errors
        for (Case c : cases) {
            if (!closing.contains(c.Id)) continue;

            if (String.isBlank(c.Description)) {
                c.addError('A resolution summary is required before closing.');
            }
            Integer open = openTasks.get(c.Id);
            if (open != null && open > 0) {
                c.addError('Cannot close: ' + open + ' open task(s) remain.');
            }
        }
    }
}

The early return matters more than it looks. This trigger fires on every Case save in the org; without it you'd burn a SOQL query on saves that have nothing to do with closure.
