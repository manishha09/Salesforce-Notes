Refactor 1 — Account defaults

trigger AccountTrigger on Account (
    before insert, before update, before delete,
    after insert, after update, after delete, after undelete
) {
    new AccountTriggerHandler().run();
}
apex
public with sharing class AccountTriggerHandler extends TriggerHandler {

    private List<Account>    newList = (List<Account>) Trigger.new;
    private Map<Id, Account> oldMap  = (Map<Id, Account>) Trigger.oldMap;

    protected override void beforeInsert() {
        AccountService.applyDefaults(newList);
    }

    protected override void beforeUpdate() {
        AccountService.applyDefaults(newList);
    }
}

public with sharing class AccountService {

    private static final String DEFAULT_COUNTRY = 'India';

    public static void applyDefaults(List<Account> accts) {

        AccountDefaults__c cfg = AccountDefaults__c.getInstance();
        String fallbackRating = (cfg != null && String.isNotBlank(cfg.Rating__c))
            ? cfg.Rating__c : 'Warm';

        for (Account a : accts) {
            if (String.isBlank(a.Rating))          a.Rating = fallbackRating;
            if (String.isBlank(a.Type))            a.Type = 'Prospect';
            if (a.AnnualRevenue == null)           a.AnnualRevenue = 0;
            if (String.isBlank(a.BillingCountry))  a.BillingCountry = DEFAULT_COUNTRY;
            if (String.isNotBlank(a.Name))         a.Name = a.Name.trim();
        }
    }
}

What the refactor bought: applyDefaults is now callable in a test with new List<Account>{ new Account(Name = ' x ') } — no DML, no governor cost, runs in milliseconds. That was impossible when the same code lived behind Trigger.new.

